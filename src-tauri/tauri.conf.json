{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BronzeForge Manager",
  "version": "0.1.0",
  "identifier": "com.medlinforge.bronzeforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BronzeForge Manager",
        "width": 1520,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
